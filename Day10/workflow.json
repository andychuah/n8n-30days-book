{
  "name": "Day 10 - Google Sheets 中央資料庫",
  "nodes": [
    {
      "id": "1",
      "type": "n8n-nodes-base.googleSheetsTrigger",
      "typeVersion": 1,
      "name": "Google Sheets 新資料觸發",
      "parameters": {
        "sheetId": "YOUR_SHEET_ID",
        "event": "rowAdded"
      },
      "position": [
        250,
        300
      ]
    },
    {
      "id": "2",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "name": "整理資料格式",
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "name",
              "value": "={{ $json.姓名 }}",
              "type": "string"
            },
            {
              "id": "2",
              "name": "email",
              "value": "={{ $json.Email }}",
              "type": "string"
            },
            {
              "id": "3",
              "name": "timestamp",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        }
      },
      "position": [
        450,
        300
      ]
    }
  ],
  "connections": {
    "Google Sheets 新資料觸發": {
      "main": [
        [
          {
            "node": "整理資料格式",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {},
  "meta": {
    "instanceId": "n8n-30days-demo"
  },
  "description": "Day 10：Google Sheets 觸發 - 有人填表就自動執行"
}